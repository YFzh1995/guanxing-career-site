---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pt-8">
    <section id="about" class="app-prose mb-28 max-w-app">
      <h1 class="font-serif text-3xl font-extrabold text-heading tracking-[-0.02em] sm:text-4xl mb-8">{frontmatter.title}</h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
