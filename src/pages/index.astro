---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PostCard from "@/components/PostCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getPostsByCategory from "@/utils/getPostsByCategory";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.draft);
const categories = getPostsByCategory(posts, 3);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="relative w-full flex flex-col items-center justify-center pt-32 pb-12 overflow-hidden">
  
      <div class="absolute inset-0 z-0">
        <div class="w-full h-full bg-[url('/hero-bg2.jpg')] bg-cover bg-center bg-no-repeat"></div>
      </div>
      <div class="absolute inset-0 z-10 bg-black/60"></div>
      <div class="absolute inset-x-0 bottom-0 z-20 h-[150px] bg-gradient-to-t from-white to-transparent"></div>

      <div class="relative z-30 flex flex-col items-center text-center px-4 w-full max-w-5xl mx-auto pb-24">
        
        <h1 class="text-white font-serif font-black leading-[1.8] tracking-widest text-2xl md:text-3xl mb-8">
          <span class="block">驱动职场进化的，</span>
          <span class="block">不是读过多少书，考过什么证，加过多少班，</span>
          <span class="block text-gray-100 mt-2">而是认知、策略和抉择</span>
        </h1>

        <p class="text-gray-200 text-sm md:text-base tracking-wider mb-8">
          拆解财务职场真相，解构职业发展的底层逻辑。
        </p>

      </div>
    </section>

    <div class="app-layout pt-10 bg-background">
      <div class="flex items-center gap-4 mb-8 pb-3 border-b border-slate-50 overflow-x-auto">
        {
          categories.map(category => (
            <a
              href={`/categories/${category.key}/`}
              class="category-pill whitespace-nowrap"
            >
              {category.key}
              <span class="text-slate-300 ms-1">{category.count}</span>
            </a>
          ))
        }
      </div>

      <section id="recent-posts">
        <ul>
          {recentPosts.slice(0, SITE.postPerIndex + 2).map(post => (
            <PostCard {...post} />
          ))}
        </ul>
      </section>

      <div class="py-8 text-center">
        <a
          href="/posts/"
          class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent/80 transition-colors"
        >
          查看全部文章
          <IconArrowRight class="size-4 rtl:-rotate-180" />
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
